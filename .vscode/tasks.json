{
  "version": "2.0.0",
  "tasks": [
    // デバッグ前のBackendビルドに使うタスク。
    {
      "label": "npm: build (backend)",
      "type": "shell",
      "command": "npm",
      "args": ["run", "build"],
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": ["$tsc"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
